rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function authEmail() {
      return request.auth.token.email.lower();
    }

    function isAdmin() {
      return signedIn()
        && ((exists(/databases/$(database)/documents/planning-avd-admins/$(request.auth.uid))
            && get(/databases/$(database)/documents/planning-avd-admins/$(request.auth.uid)).data.active != false)
          || (exists(/databases/$(database)/documents/planning-avd-admin-bootstraps/$(authEmail()))
            && get(/databases/$(database)/documents/planning-avd-admin-bootstraps/$(authEmail())).data.active == true)
          || (exists(/databases/$(database)/documents/planning-avd-admins/$(authEmail()))
            && get(/databases/$(database)/documents/planning-avd-admins/$(authEmail())).data.active == true)
          || (exists(/databases/$(database)/documents/planning-avd-admin-emails/$(authEmail()))
            && get(/databases/$(database)/documents/planning-avd-admin-emails/$(authEmail())).data.active == true));
    }

    function isTeamMember() {
      return signedIn()
        && (isAdmin()
          || (exists(/databases/$(database)/documents/planning-avd-team-members/$(authEmail()))
            && get(/databases/$(database)/documents/planning-avd-team-members/$(authEmail())).data.active == true));
    }

    function canContribute() {
      return signedIn()
        && (isAdmin()
          || (exists(/databases/$(database)/documents/planning-avd-team-members/$(authEmail()))
            && get(/databases/$(database)/documents/planning-avd-team-members/$(authEmail())).data.active == true
            && get(/databases/$(database)/documents/planning-avd-team-members/$(authEmail())).data.role != "viewer"));
    }

    function hasBeneficiaryMemberDoc(beneficiaryId) {
      return signedIn()
        && exists(/databases/$(database)/documents/planning-avd-beneficiaries/$(beneficiaryId)/members/$(authEmail()))
        && get(/databases/$(database)/documents/planning-avd-beneficiaries/$(beneficiaryId)/members/$(authEmail())).data.active == true;
    }

    function hasBeneficiaryShare(beneficiaryId) {
      return signedIn()
        && exists(/databases/$(database)/documents/planning-avd-shares/$(authEmail())/beneficiaries/$(beneficiaryId));
    }

    function hasBeneficiaryBootstrap(beneficiaryId) {
      return signedIn()
        && exists(/databases/$(database)/documents/planning-avd-admin-bootstraps/$(authEmail()))
        && get(/databases/$(database)/documents/planning-avd-admin-bootstraps/$(authEmail())).data.active == true
        && get(/databases/$(database)/documents/planning-avd-admin-bootstraps/$(authEmail())).data.beneficiaryId == beneficiaryId;
    }

    function isBeneficiaryMember(beneficiaryId) {
      return hasBeneficiaryMemberDoc(beneficiaryId)
        || hasBeneficiaryShare(beneficiaryId)
        || hasBeneficiaryBootstrap(beneficiaryId);
    }

    function canContributeBeneficiary(beneficiaryId) {
      return (hasBeneficiaryMemberDoc(beneficiaryId)
          && get(/databases/$(database)/documents/planning-avd-beneficiaries/$(beneficiaryId)/members/$(authEmail())).data.role != "viewer")
        || (hasBeneficiaryShare(beneficiaryId) && canContribute())
        || hasBeneficiaryBootstrap(beneficiaryId);
    }

    function isBeneficiaryAdmin(beneficiaryId) {
      return (hasBeneficiaryMemberDoc(beneficiaryId)
          && get(/databases/$(database)/documents/planning-avd-beneficiaries/$(beneficiaryId)/members/$(authEmail())).data.role in ["admin", "owner"])
        || hasBeneficiaryBootstrap(beneficiaryId);
    }

    match /planning-avd-users/{userId}/{document=**} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /planning-avd-admins/{userId} {
      allow read: if signedIn()
        && (request.auth.uid == userId
          || authEmail() == userId
          || resource.data.email == authEmail()
          || resource.data.emailLower == authEmail()
          || isAdmin());
      allow create, update: if isAdmin();
      allow delete: if isAdmin() && request.auth.uid != userId && authEmail() != userId;
    }

    match /planning-avd-admin-emails/{email} {
      allow read: if signedIn() && (authEmail() == email || isAdmin());
      allow create, update: if isAdmin();
      allow delete: if isAdmin() && authEmail() != email;
    }

    match /planning-avd-admin-bootstraps/{email} {
      allow read: if signedIn() && (authEmail() == email || isAdmin());
      allow create: if signedIn()
        && authEmail() == email
        && request.resource.data.email == authEmail()
        && request.resource.data.emailLower == authEmail()
        && request.resource.data.role == "admin"
        && request.resource.data.active == true
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.beneficiaryName is string
        && request.resource.data.beneficiaryName.size() > 0
        && request.resource.data.beneficiaryName.size() <= 120;
      allow update: if isAdmin()
        || (signedIn()
          && authEmail() == email
          && resource.data.createdByUid == request.auth.uid
          && request.resource.data.email == authEmail()
          && request.resource.data.emailLower == authEmail()
          && request.resource.data.role == "admin"
          && request.resource.data.active == true
          && request.resource.data.beneficiaryName is string
          && request.resource.data.beneficiaryName.size() > 0
          && request.resource.data.beneficiaryName.size() <= 120);
      allow delete: if isAdmin() && authEmail() != email;
    }

    match /planning-avd-access-requests/{email} {
      allow read: if signedIn() && (authEmail() == email || isAdmin());
      allow create: if signedIn()
        && authEmail() == email
        && request.resource.data.email == authEmail()
        && request.resource.data.role in ["admin", "auxiliary", "viewer"]
        && request.resource.data.status == "pending";
      allow update: if isAdmin()
        || (signedIn()
          && authEmail() == email
          && resource.data.status != "approved"
          && request.resource.data.email == authEmail()
          && request.resource.data.role in ["admin", "auxiliary", "viewer"]
          && request.resource.data.status == "pending");
      allow delete: if isAdmin();
    }

    match /planning-avd-shares/{email}/months/{month} {
      allow read: if signedIn()
        && (authEmail() == email
          || authEmail() == resource.data.email
          || authEmail() == resource.data.emailOriginal
          || (resource.data.readEmails is list
            && authEmail() in resource.data.readEmails));
      allow write: if isAdmin();
    }

    match /planning-avd-shares/{email}/beneficiaries/{beneficiaryId} {
      allow read: if signedIn()
        && (authEmail() == email
          || authEmail() == resource.data.email
          || authEmail() == resource.data.emailOriginal
          || (resource.data.readEmails is list
            && authEmail() in resource.data.readEmails));
      allow write: if isAdmin();

      match /months/{month} {
        allow read: if signedIn()
          && (authEmail() == email
            || authEmail() == resource.data.email
            || authEmail() == resource.data.emailOriginal
            || (resource.data.readEmails is list
              && authEmail() in resource.data.readEmails));
        allow write: if isAdmin();
      }
    }

    match /planning-avd-change-requests/{email}/months/{month}/items/{requestId} {
      allow create: if canContribute()
        && request.resource.data.requesterEmail == authEmail()
        && request.resource.data.status == "pending";
      allow read: if request.auth != null
        && (resource.data.requesterEmail == authEmail() || isAdmin());
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /planning-avd-change-requests/{email}/beneficiaries/{beneficiaryId}/months/{month}/items/{requestId} {
      allow create: if canContributeBeneficiary(beneficiaryId)
        && request.resource.data.requesterEmail == authEmail()
        && request.resource.data.beneficiaryId == beneficiaryId
        && request.resource.data.status == "pending";
      allow read: if request.auth != null
        && (resource.data.requesterEmail == authEmail() || isBeneficiaryAdmin(beneficiaryId));
      allow update: if isBeneficiaryAdmin(beneficiaryId);
      allow delete: if false;
    }

    match /planning-avd-team-members/{email} {
      allow read: if signedIn()
        && (authEmail() == email
          || authEmail() == resource.data.email
          || authEmail() == resource.data.emailLower
          || isAdmin());
      allow write: if isAdmin();
    }

    match /planning-avd-beneficiaries/{beneficiaryId} {
      allow read: if isBeneficiaryMember(beneficiaryId);
      allow create, update: if isAdmin() || isBeneficiaryAdmin(beneficiaryId);
      allow delete: if false;

      match /members/{email} {
        allow read: if signedIn() && (authEmail() == email || isBeneficiaryMember(beneficiaryId));
        allow create, update: if isAdmin() || isBeneficiaryAdmin(beneficiaryId);
        allow delete: if isBeneficiaryAdmin(beneficiaryId);
      }

      match /tasks/{taskId} {
        allow read: if isBeneficiaryMember(beneficiaryId);
        allow create: if canContributeBeneficiary(beneficiaryId)
          && request.resource.data.beneficiaryId == beneficiaryId
          && request.resource.data.title is string
          && request.resource.data.title.size() > 0
          && request.resource.data.title.size() <= 160
          && request.resource.data.priority in ["normal", "important", "urgent"]
          && request.resource.data.completed == false
          && request.resource.data.createdByUid == request.auth.uid
          && request.resource.data.createdByEmail == authEmail();
        allow update: if canContributeBeneficiary(beneficiaryId)
          && resource.data.beneficiaryId == beneficiaryId
          && request.resource.data.beneficiaryId == beneficiaryId
          && (isBeneficiaryAdmin(beneficiaryId)
            || (request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(["completed", "completedAt", "completedBy", "updatedAt"])
              && request.resource.data.completedBy == authEmail()));
        allow delete: if isBeneficiaryAdmin(beneficiaryId);
      }

      match /shopping/{weekId} {
        allow read: if isBeneficiaryMember(beneficiaryId);
        allow create, update: if canContributeBeneficiary(beneficiaryId)
          && request.resource.data.beneficiaryId == beneficiaryId;
        allow delete: if isBeneficiaryAdmin(beneficiaryId);
      }

      match /activity/{activityId} {
        allow read: if isBeneficiaryMember(beneficiaryId);
        allow create: if isBeneficiaryAdmin(beneficiaryId)
          && request.resource.data.beneficiaryId == beneficiaryId
          && request.resource.data.actorEmail == authEmail();
        allow update, delete: if false;
      }
    }

    match /planning-avd-tasks/{taskId} {
      allow read, create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /planning-avd-shopping/{weekId} {
      allow read, create, update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}

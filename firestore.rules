rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && (exists(/databases/$(database)/documents/planning-avd-admins/$(request.auth.uid))
          || (request.auth.token.email is string
            && exists(/databases/$(database)/documents/planning-avd-admin-emails/$(request.auth.token.email))
            && get(/databases/$(database)/documents/planning-avd-admin-emails/$(request.auth.token.email)).data.active == true));
    }

    function isTeamMember() {
      return signedIn()
        && (isAdmin()
          || (exists(/databases/$(database)/documents/planning-avd-team-members/$(request.auth.token.email))
            && get(/databases/$(database)/documents/planning-avd-team-members/$(request.auth.token.email)).data.active == true));
    }

    match /planning-avd-users/{userId}/{document=**} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /planning-avd-admins/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow write: if false;
    }

    match /planning-avd-admin-emails/{email} {
      allow read: if signedIn() && (request.auth.token.email == email || isAdmin());
      allow create, update: if isAdmin()
        && request.resource.data.email == email
        && request.resource.data.active == true;
      allow delete: if isAdmin() && request.auth.token.email != email;
    }

    match /planning-avd-shares/{email}/months/{month} {
      allow read: if signedIn()
        && request.auth.token.email == resource.data.email;
      allow write: if isAdmin();
    }

    match /planning-avd-change-requests/{email}/months/{month}/items/{requestId} {
      allow create: if request.auth != null
        && request.resource.data.requesterEmail == request.auth.token.email
        && request.resource.data.status == "pending";
      allow read: if request.auth != null
        && (resource.data.requesterEmail == request.auth.token.email || isAdmin());
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /planning-avd-team-members/{email} {
      allow read: if signedIn() && (request.auth.token.email == email || isAdmin());
      allow write: if isAdmin();
    }

    match /planning-avd-tasks/{taskId} {
      allow read: if isTeamMember();
      allow create: if isTeamMember()
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 160
        && request.resource.data.priority in ["normal", "important", "urgent"]
        && request.resource.data.completed == false
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.createdByEmail == request.auth.token.email;
      allow update: if isTeamMember()
        && (isAdmin()
          || (request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["completed", "completedAt", "completedBy", "updatedAt"])
            && request.resource.data.completedBy == request.auth.token.email));
      allow delete: if isAdmin();
    }

    match /planning-avd-shopping/{weekId} {
      allow read, create, update: if isTeamMember();
      allow delete: if isAdmin();
    }
  }
}

# Configuration Google Sign-In via Firebase Auth pour Planning-AVD
# A reporter dans auth-config.js pour GitHub Pages statique.

VITE_FIREBASE_API_KEY=votre-api-key
VITE_FIREBASE_AUTH_DOMAIN=votre-projet.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=votre-project-id
VITE_FIREBASE_APP_ID=votre-app-id
# Optionnel : laisser vide pour autoriser tout compte Google.
VITE_ALLOWED_EMAILS=adresse1@gmail.com,adresse2@gmail.com
